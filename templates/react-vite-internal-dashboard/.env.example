# No NEXT_PUBLIC_ prefix needed for Vite.
# Vite uses VITE_ prefix for client-exposed vars, but the Tide React SDK
# reads config from the adapter JSON file (public/tidecloak.json), not env vars.
# These are for your reference / backend config only.
TIDECLOAK_URL=http://localhost:8080
TIDECLOAK_REALM=myrealm
TIDECLOAK_CLIENT_ID=myclient
